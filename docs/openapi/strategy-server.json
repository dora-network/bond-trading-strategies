{
  "openapi": "3.1.0",
  "info": {
    "title": "Strategy Service API",
    "version": "1.3.0",
    "description": "REST API for asynchronous strategy backtests, live strategy runs, and strategy discovery.\n\nAll endpoints except `/healthz` require `Authorization: ApiKey <key>` or `Authorization: Bearer <token>`."
  },
  "servers": [
    {
      "url": "http://localhost:8081"
    }
  ],
  "tags": [
    {
      "name": "notifications",
      "description": "Real-time lifecycle notifications delivered over a WebSocket."
    }
  ],
  "paths": {
    "/healthz": {
      "get": {
        "operationId": "getHealth",
        "summary": "Health check — exempt from authentication",
        "responses": {
          "200": {
            "description": "Server is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    }
                  },
                  "required": ["ok"]
                }
              }
            }
          }
        }
      }
    },
    "/v1/dora/orderbooks": {
      "get": {
        "operationId": "listDORAOrderBooks",
        "summary": "List DORA order books available to the configured API key",
        "security": [{ "ApiKeyAuth": [] }],
        "responses": {
          "200": {
            "description": "DORA order books",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/DORAOrderBookSummary" }
                    }
                  }
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/v1/dora/user": {
      "get": {
        "operationId": "getDORAUser",
        "summary": "Look up the current DORA user for the configured API key",
        "security": [{ "ApiKeyAuth": [] }],
        "responses": {
          "200": {
            "description": "Current DORA user",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DORAUserSummary" }
              }
            }
          },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/v1/copy-traders": {
      "get": {
        "operationId": "listCopyTraders",
        "summary": "List traders available to be followed by a copy-trading run",
        "security": [{ "ApiKeyAuth": [] }],
        "responses": {
          "200": {
            "description": "Available copy traders",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/CopyTraderSummary" }
                    }
                  }
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/v1/tenors": {
      "get": {
        "operationId": "listTenors",
        "summary": "List supported benchmark Treasury tenors",
        "security": [{ "ApiKeyAuth": [] }],
        "responses": {
          "200": {
            "description": "Supported benchmark tenors",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/TenorSummary" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/strategies": {
      "get": {
        "operationId": "listStrategies",
        "summary": "List available strategies and their capabilities",
        "security": [{ "ApiKeyAuth": [] }],
        "responses": {
          "200": {
            "description": "Registered strategies",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/StrategySummary" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/backtests": {
      "get": {
        "operationId": "listBacktests",
        "summary": "List all backtests for the authenticated user",
        "security": [{ "ApiKeyAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/Page" },
          { "$ref": "#/components/parameters/Limit" },
          {
            "name": "status",
            "in": "query",
            "description": "Comma-separated status filter: running,completed,failed,cancelled",
            "schema": { "type": "string" }
          },
          {
            "name": "from",
            "in": "query",
            "description": "Earliest created_at (RFC3339 or YYYY-MM-DD)",
            "schema": { "type": "string" }
          },
          {
            "name": "to",
            "in": "query",
            "description": "Latest created_at (RFC3339 or YYYY-MM-DD)",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated backtest summaries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/BacktestSummary" }
                    },
                    "page": { "type": "integer" },
                    "limit": { "type": "integer" }
                  }
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      },
      "post": {
        "operationId": "createBacktest",
        "summary": "Create a new asynchronous backtest",
        "security": [{ "ApiKeyAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateBacktestRequest" }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Backtest accepted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BacktestDetail" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "501": { "$ref": "#/components/responses/NotImplemented" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/v1/backtests/{id}": {
      "parameters": [{ "$ref": "#/components/parameters/ID" }],
      "get": {
        "operationId": "getBacktest",
        "summary": "Get summarised backtest result by ID",
        "description": "Returns a flattened result summary (total_pnl, win_count, etc.) rather than the full BacktestDetail. For metadata-only lookups (id, status, timestamps) use the /metadata sub-resource.",
        "security": [{ "ApiKeyAuth": [] }],
        "responses": {
          "200": {
            "description": "Backtest result summary",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BacktestResultSummary" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "operationId": "cancelBacktest",
        "summary": "Cancel / delete a backtest",
        "security": [{ "ApiKeyAuth": [] }],
        "responses": {
          "200": {
            "description": "Backtest cancelled — returns updated metadata",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BacktestSummary" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/v1/backtests/{id}/trades": {
      "parameters": [
        { "$ref": "#/components/parameters/ID" },
        { "$ref": "#/components/parameters/Page" },
        { "$ref": "#/components/parameters/Limit" }
      ],
      "get": {
        "operationId": "getBacktestTrades",
        "summary": "Get paginated trade records for a completed backtest",
        "security": [{ "ApiKeyAuth": [] }],
        "responses": {
          "200": {
            "description": "Paginated trade records",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/TradeRecord" }
                    }
                  }
                }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/v1/backtests/{id}/closed-trades": {
      "parameters": [
        { "$ref": "#/components/parameters/ID" },
        { "$ref": "#/components/parameters/Page" },
        { "$ref": "#/components/parameters/Limit" }
      ],
      "get": {
        "operationId": "getBacktestClosedTrades",
        "summary": "Get paginated closed trades for a completed backtest",
        "security": [{ "ApiKeyAuth": [] }],
        "responses": {
          "200": {
            "description": "Paginated closed trades",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/ClosedTrade" }
                    }
                  }
                }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/v1/backtests/{id}/metadata": {
      "parameters": [{ "$ref": "#/components/parameters/ID" }],
      "get": {
        "operationId": "getBacktestMetadata",
        "summary": "Get backtest metadata (ID, status, timestamps) — lighter than full detail",
        "security": [{ "ApiKeyAuth": [] }],
        "responses": {
          "200": {
            "description": "Backtest metadata",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BacktestSummary" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/v1/runs": {
      "get": {
        "operationId": "listRuns",
        "summary": "List all strategy runs for the authenticated user",
        "security": [{ "ApiKeyAuth": [] }],
        "responses": {
          "200": {
            "description": "Run summaries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/RunSummary" }
                    }
                  }
                }
              }
            }
          },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      },
      "post": {
        "operationId": "createRun",
        "summary": "Create a new live strategy run",
        "security": [{ "ApiKeyAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateRunRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Run created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RunDetail" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "501": { "$ref": "#/components/responses/NotImplemented" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/v1/runs/{id}": {
      "parameters": [{ "$ref": "#/components/parameters/ID" }],
      "get": {
        "operationId": "getRun",
        "summary": "Get a specific run by ID",
        "security": [{ "ApiKeyAuth": [] }],
        "responses": {
          "200": {
            "description": "Run detail",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RunDetail" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "operationId": "stopRun",
        "summary": "Stop and delete a strategy run",
        "security": [{ "ApiKeyAuth": [] }],
        "responses": {
          "200": {
            "description": "Run stopped",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RunDetail" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/v1/runs/{id}/pause": {
      "parameters": [{ "$ref": "#/components/parameters/ID" }],
      "post": {
        "operationId": "pauseRun",
        "summary": "Pause a running strategy",
        "security": [{ "ApiKeyAuth": [] }],
        "responses": {
          "200": {
            "description": "Run paused",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RunDetail" }
              }
            }
          },
          "409": { "$ref": "#/components/responses/Conflict" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/v1/runs/{id}/resume": {
      "parameters": [{ "$ref": "#/components/parameters/ID" }],
      "post": {
        "operationId": "resumeRun",
        "summary": "Resume a paused strategy",
        "security": [{ "ApiKeyAuth": [] }],
        "responses": {
          "200": {
            "description": "Run resumed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RunDetail" }
              }
            }
          },
          "409": { "$ref": "#/components/responses/Conflict" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "500": { "$ref": "#/components/responses/InternalError" }
        }
      }
    },
    "/v1/notifications/ws": {
      "get": {
        "tags": ["notifications"],
        "operationId": "subscribeNotifications",
        "summary": "Open a WebSocket connection for real-time lifecycle notifications",
        "description": "Upgrades the HTTP connection to a WebSocket. The server authenticates using the standard Authorization header (ApiKey <key> or Bearer <token>), resolves the DORA user, and streams JSON-encoded Event objects as text frames. Clients that cannot set request headers may alternatively pass `x-api-key` as a query parameter; the header takes precedence when both are present. Optional query params: Last-Event-ID (UUIDv7) replays events from the log; types (comma-separated) filters by EventType. Heartbeat is WS-level ping/pong every 30s.",
        "security": [{ "ApiKeyAuth": [] }],
        "parameters": [
          {
            "name": "Last-Event-ID",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "format": "uuid" },
            "description": "Replay events with id > Last-Event-ID (UUIDv7). Capped at 1000 events or 24h, whichever is smaller."
          },
          {
            "name": "types",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Comma-separated whitelist of EventType values. Default: all."
          },
          {
            "name": "x-api-key",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Alternative to the Authorization header for clients that cannot set request headers on the WebSocket handshake. Ignored when the Authorization header is present."
          }
        ],
        "responses": {
          "101": {
            "description": "Switching Protocols — WebSocket upgrade succeeded"
          },
          "401": {
            "description": "Missing or invalid Authorization header"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Format: `ApiKey <key>` or `Bearer <token>`"
      }
    },
    "parameters": {
      "ID": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "string", "format": "uuid" }
      },
      "Page": {
        "name": "page",
        "in": "query",
        "description": "Page number (default 1)",
        "schema": { "type": "integer", "minimum": 1, "default": 1 }
      },
      "Limit": {
        "name": "limit",
        "in": "query",
        "description": "Items per page (default 10, max 50)",
        "schema": { "type": "integer", "minimum": 1, "maximum": 50, "default": 10 }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Invalid request",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "NotImplemented": {
        "description": "Strategy is known but not implemented for the requested operation",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "Conflict": {
        "description": "A strategy is already active for this order book",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "InternalError": {
        "description": "Internal server error",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    },
    "schemas": {
      "DORAOrderBookSummary": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "display_name": { "type": "string" },
          "base_asset_id": { "type": "string" },
          "quote_asset_id": { "type": "string" },
          "status": { "type": "string" }
        },
        "required": ["id", "display_name", "base_asset_id", "quote_asset_id", "status"]
      },
      "DORAUserSummary": {
        "type": "object",
        "properties": {
          "id": { "type": "string" }
        },
        "required": ["id"]
      },
      "CopyTraderSummary": {
        "type": "object",
        "description": "A single entry in the list-copy-traders response. The `id` is the DORA user id and matches the `followed_trader` field accepted by CopyTradingConfig.",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "display_name": { "type": "string" }
        },
        "required": ["id", "display_name"]
      },
      "TenorSummary": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "description": { "type": "string" }
        },
        "required": ["code", "description"]
      },
      "StrategySummary": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "status": { "type": "string", "enum": ["available", "not_implemented"] },
          "description": { "type": "string" },
          "config_fields": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/StrategyConfigField" }
          },
          "supports_run": { "type": "boolean" },
          "supports_backtest": { "type": "boolean" }
        },
        "required": ["type", "status", "supports_run", "supports_backtest"]
      },
      "StrategyConfigField": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "description": { "type": "string" },
          "required": { "type": "boolean" },
          "default": {}
        },
        "required": ["name", "type", "description", "required"]
      },
      "CreateBacktestRequest": {
        "type": "object",
        "properties": {
          "strategy_type": { "type": "string", "enum": ["mean_reversion", "copytrading"] },
          "config": {
            "oneOf": [
              { "$ref": "#/components/schemas/MeanReversionConfig" },
              { "$ref": "#/components/schemas/CopyTradingConfig" }
            ]
          },
          "start": { "type": "string", "format": "date-time" },
          "end": { "type": "string", "format": "date-time" }
        },
        "required": ["strategy_type", "config", "start", "end"]
      },
      "CreateRunRequest": {
        "type": "object",
        "properties": {
          "strategy_type": { "type": "string", "enum": ["mean_reversion", "copytrading"] },
          "config": {
            "oneOf": [
              { "$ref": "#/components/schemas/MeanReversionConfig" },
              { "$ref": "#/components/schemas/CopyTradingConfig" }
            ]
          }
        },
        "required": ["strategy_type", "config"]
      },
      "MeanReversionConfig": {
        "type": "object",
        "properties": {
          "lookback_window": { "type": "integer", "minimum": 2, "default": 20 },
          "entry_z_score": { "type": "number", "exclusiveMinimum": 0, "default": 2.0 },
          "exit_z_score": { "type": "number", "minimum": 0, "default": 0.5 },
          "stop_loss_z_score": { "type": "number", "minimum": 0, "default": 3.5 },
          "min_std_dev": { "type": "number", "minimum": 0, "default": 0.0005 },
          "max_position_size": { "type": "number", "exclusiveMinimum": 0, "maximum": 1, "default": 1.0 },
          "order_book_id": {
            "type": "string", "format": "uuid",
            "description": "DORA order book UUID used to locate the traded asset and place orders."
          },
          "tenor": {
            "type": "string",
            "description": "Benchmark Treasury tenor, e.g. 1M, 6M, 2Y, 5Y, 10Y, 30Y."
          },
          "initial_balance": {
            "type": "number", "exclusiveMinimum": 0,
            "default": 1.0,
            "description": "Starting capital for backtests. Omitted for live runs — obtained from DORA positions."
          },
          "leverage": {
            "type": "number", "exclusiveMinimum": 0, "default": 1.0,
            "description": "Leverage multiplier for live orders."
          }
        }
      },
      "CopyTradingConfig": {
        "type": "object",
        "properties": {
          "followed_trader": {
            "type": "string", "format": "uuid",
            "description": "DORA user id of the trader whose trades will be copied."
          },
          "percentage_of_available": {
            "type": "number",
            "exclusiveMinimum": 0, "maximum": 1,
            "description": "Fraction of available balance to allocate per copied trade. Must be in (0, 1]."
          },
          "leverage": {
            "type": "number",
            "exclusiveMinimum": 0,
            "description": "Leverage multiplier applied to copied orders. Must be greater than 0."
          },
          "min_order_size": {
            "type": "integer", "minimum": 0,
            "description": "Minimum order size; orders below this threshold are skipped. Defaults to 0."
          },
          "max_order_size": {
            "type": "integer", "minimum": 0,
            "description": "Maximum order size; orders above this threshold are clipped. Must be >= min_order_size. Defaults to 0 (no cap)."
          },
          "disallowed_bonds": {
            "type": "array",
            "items": { "type": "string", "format": "uuid" },
            "description": "Bond UUIDs to exclude from copying. If absent or empty, all bonds are eligible."
          },
          "initial_balance": {
            "type": "number", "minimum": 0, "default": 10000,
            "description": "Starting cash for backtests. Omit or set to 0 to use the package default (10000). Omitted for live runs — obtained from DORA positions."
          }
        },
        "required": ["followed_trader", "percentage_of_available", "leverage"]
      },
      "BacktestSummary": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "dora_user_id": { "type": "string" },
          "strategy_type": { "type": "string" },
          "status": { "type": "string", "enum": ["running", "completed", "failed", "cancelled"] },
          "config": { "description": "Normalised strategy config JSON" },
          "asset_name": { "type": "string" },
          "asset_symbol": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "completed_at": { "type": "string", "format": "date-time", "nullable": true },
          "error": { "type": "string", "description": "Error message if the backtest failed" }
        },
        "required": ["id", "dora_user_id", "strategy_type", "status", "created_at"]
      },
      "BacktestDetail": {
        "allOf": [
          { "$ref": "#/components/schemas/BacktestSummary" },
          {
            "type": "object",
            "properties": {
              "start": { "type": "string", "format": "date-time" },
              "end": { "type": "string", "format": "date-time" },
              "result": { "$ref": "#/components/schemas/BacktestResult" },
              "error": { "type": "string" }
            },
            "required": ["start", "end"]
          }
        ]
      },
      "BacktestResultSummary": {
        "type": "object",
        "description": "Flattened backtest result returned by GET /v1/backtests/{id}. Mirrors the Go BacktestResultSummary struct — contains result fields at top level alongside strategy type, status, and config, but omits id, dora_user_id, and timestamps.",
        "properties": {
          "total_pnl": { "type": "string", "description": "Total realised P&L" },
          "win_count": { "type": "integer" },
          "loss_count": { "type": "integer" },
          "max_drawdown": { "type": "string" },
          "sharpe_ratio": { "type": "string" },
          "strategy_type": { "type": "string" },
          "status": { "type": "string", "enum": ["running", "completed", "failed", "cancelled"] },
          "config": { "description": "Normalised strategy config JSON" },
          "asset_name": { "type": "string" },
          "asset_symbol": { "type": "string" },
          "error": { "type": "string", "description": "Error message if the backtest failed" }
        },
        "required": ["strategy_type", "status"]
      },
      "BacktestResult": {
        "type": "object",
        "properties": {
          "closed_trades": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ClosedTrade" }
          },
          "trade_records": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/TradeRecord" }
          },
          "total_pnl": { "type": "string" },
          "win_count": { "type": "integer" },
          "loss_count": { "type": "integer" },
          "max_drawdown": { "type": "string" },
          "sharpe_ratio": { "type": "string" }
        },
        "required": ["closed_trades", "trade_records", "total_pnl", "win_count", "loss_count", "max_drawdown", "sharpe_ratio"]
      },
      "ClosedTrade": {
        "type": "object",
        "properties": {
          "bond_id": { "type": "string" },
          "open_time": { "type": "string", "format": "date-time" },
          "close_time": { "type": "string", "format": "date-time" },
          "signal": { "type": "string", "enum": ["BUY", "SELL", "HOLD"] },
          "exit_signal": { "type": "string", "enum": ["BUY", "SELL", "HOLD"] },
          "entry_spread": { "type": "string" },
          "exit_spread": { "type": "string" },
          "entry_zscore": { "type": "string" },
          "exit_zscore": { "type": "string" },
          "position_size": { "type": "string" },
          "pnl": { "type": "string" },
          "exit_reason": { "type": "string" },
          "entry_price": { "type": "string" },
          "exit_price": { "type": "string" },
          "quantity": { "type": "string" },
          "entry_balance": { "type": "string" }
        },
        "required": ["bond_id", "open_time", "close_time", "signal", "entry_spread", "exit_spread", "position_size", "pnl"]
      },
      "TradeRecord": {
        "type": "object",
        "properties": {
          "time": { "type": "string", "format": "date-time" },
          "bond_id": { "type": "string" },
          "signal": { "type": "string", "enum": ["BUY", "SELL", "HOLD"] },
          "spread": { "type": "string" },
          "position_size": { "type": "string" },
          "zscore": { "type": "string" },
          "price": { "type": "string" },
          "quantity": { "type": "string" },
          "entry_balance": { "type": "string" }
        },
        "required": ["time", "bond_id", "signal", "price"]
      },
      "RunSummary": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "dora_user_id": { "type": "string" },
          "strategy_type": { "type": "string" },
          "status": { "type": "string", "enum": ["running", "paused", "stopped"] },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
          "stopped_at": { "type": "string", "format": "date-time", "nullable": true }
        },
        "required": ["id", "dora_user_id", "strategy_type", "status", "created_at", "updated_at"]
      },
      "RunDetail": {
        "allOf": [
          { "$ref": "#/components/schemas/RunSummary" },
          {
            "type": "object",
            "properties": {
              "config": {
                "oneOf": [
                  { "$ref": "#/components/schemas/MeanReversionConfig" },
                  { "$ref": "#/components/schemas/CopyTradingConfig" }
                ]
              },
              "error": { "type": "string" }
            },
            "required": ["config"]
          }
        ]
      },
      "EventType": {
        "type": "string",
        "enum": [
          "backtest.started",
          "backtest.completed",
          "backtest.failed",
          "run.started",
          "run.paused",
          "run.resumed",
          "run.stopped",
          "run.stop_loss"
        ]
      },
      "BacktestStartedPayload": {
        "type": "object",
        "properties": {
          "strategy_type": { "type": "string" }
        }
      },
      "BacktestCompletedPayload": {
        "type": "object",
        "properties": {
          "strategy_type": { "type": "string" }
        }
      },
      "BacktestFailedPayload": {
        "type": "object",
        "properties": {
          "error": { "type": "string" }
        },
        "required": ["error"]
      },
      "RunStartedPayload": {
        "type": "object",
        "properties": {
          "strategy_type": { "type": "string" }
        }
      },
      "RunStoppedPayload": {
        "type": "object",
        "properties": {
          "reason": { "type": "string" }
        }
      },
      "RunStopLossPayload": {
        "type": "object",
        "properties": {
          "z_score": { "type": "string" },
          "pnl": { "type": "string" }
        }
      },
      "Event": {
        "type": "object",
        "description": "A single notification event delivered over the WebSocket. New event types (notably dora.*) may appear without a spec change — clients MUST tolerate unknown values of `type`.",
        "required": ["id", "type", "user_id", "timestamp", "payload"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "UUIDv7. Monotonic; used as the Last-Event-ID replay cursor."
          },
          "type": { "$ref": "#/components/schemas/EventType" },
          "user_id": {
            "type": "string",
            "description": "DORA user id the event belongs to."
          },
          "run_id": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          },
          "backtest_id": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Event timestamp in RFC3339, always UTC."
          },
          "payload": {
            "type": "object",
            "description": "Type-specific JSON object.",
            "oneOf": [
              { "$ref": "#/components/schemas/BacktestStartedPayload" },
              { "$ref": "#/components/schemas/BacktestCompletedPayload" },
              { "$ref": "#/components/schemas/BacktestFailedPayload" },
              { "$ref": "#/components/schemas/RunStartedPayload" },
              { "$ref": "#/components/schemas/RunStoppedPayload" },
              { "$ref": "#/components/schemas/RunStopLossPayload" }
            ]
          }
        }
      },
      "NotificationLogEntry": {
        "type": "object",
        "description": "Internal. Persisted copy of an Event used for Last-Event-ID replay. Not exposed via the REST API.",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "user_id": { "type": "string" },
          "type": { "$ref": "#/components/schemas/EventType" },
          "run_id": { "type": "string", "format": "uuid", "nullable": true },
          "backtest_id": { "type": "string", "format": "uuid", "nullable": true },
          "created_at": { "type": "string", "format": "date-time" },
          "payload": { "type": "object" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": { "type": "string" }
        },
        "required": ["error"]
      }
    }
  }
}
